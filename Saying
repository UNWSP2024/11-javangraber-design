import tkinter

# Create the Gui Class
class MYGUI:
    # Create the Initializer
    def __init__(self):
        # Create the main window, title, and two labels with text
        self.main_window = tkinter.Tk()

        self.main_window.title("Javan Graber Favorite Saying")

        self.label1 = tkinter.Label(self.main_window, text="But He was pierced through for our "
                                                           "transgressions, He was crushed for our iniquities;")

        self.label2 = tkinter.Label(self.main_window, text="The chastening for our well-being fell upon "
                                                           "Him, And by His scourging we are healed. "
                                                           "- Isaiah 53:5")

        # Call the pack method and enter the loop
        self.label1.pack()
        self.label2.pack()

        tkinter.mainloop()

if __name__ == "__main__":
    mygui = MYGUI()
